<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".LoginActivity"
    android:background="#F5F4FF">

    <!-- Purple Header Banner -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#534AB7"
        android:padding="28dp"
        android:gravity="center">

        <TextView
            android:id="@+id/textView3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_login_title"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Please sign in to continue"
            android:textAlignment="center"
            android:textColor="#AFA9EC"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Form Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#FFFFFF">

        <!-- Username Label -->
        <TextView
            android:id="@+id/textView4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_username"
            android:textColor="#534AB7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Username Input -->
        <EditText
            android:id="@+id/editUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp"
            android:ems="10"
            android:hint="@string/str_hint_username"
            android:inputType="text"
            android:text="admin"
            android:padding="12dp"
            android:textColor="#26215C"
            android:textColorHint="#AFA9EC" />

        <!-- Password Label -->
        <TextView
            android:id="@+id/textView5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_password"
            android:textColor="#534AB7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Password Input -->
        <EditText
            android:id="@+id/editPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp"
            android:ems="10"
            android:hint="@string/str_hint_password"
            android:inputType="textPassword"
            android:text="123"
            android:padding="12dp"
            android:textColor="#26215C"
            android:textColorHint="#AFA9EC" />

        <!-- Role Label -->
        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_login_role"
            android:textColor="#534AB7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Radio Group -->
        <RadioGroup
            android:id="@+id/RadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radAdmin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/str_login_admin"
                android:textColor="#534AB7"
                android:buttonTint="#534AB7" />

            <RadioButton
                android:id="@+id/radEmployee"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/str_login_employee"
                android:textColor="#534AB7"
                android:buttonTint="#534AB7" />

        </RadioGroup>

        <!-- Remember Me / Forgot Password Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <CheckBox
                android:id="@+id/chkSaveInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remember Me"
                android:textColor="#534AB7"
                android:buttonTint="#534AB7" />

            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:text="Forgot Password?"
                android:textColor="#7F77DD"
                android:textStyle="bold"
                android:textSize="13sp" />

        </RelativeLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:onClick="loginSystem"
                android:id="@+id/btnLogin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/str_login"
                android:backgroundTint="#534AB7"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:onClick="exitSystem"
                android:id="@+id/btnExit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/str_exit"
                android:backgroundTint="#FAECE7"
                android:textColor="#993C1D"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Status Message -->
        <TextView
            android:id="@+id/txtMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1D9E75"
            android:textAlignment="center"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>