<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".LoginActivity"
    android:background="@color/login_background">

    <!-- Purple Header Banner -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/login_primary"
        android:padding="28dp"
        android:gravity="center">

        <TextView
            android:id="@+id/textView3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_login_title"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_signin_continue"
            android:textAlignment="center"
            android:textColor="@color/login_text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Form Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/white">

        <!-- Username Label -->
        <TextView
            android:id="@+id/textView4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_username"
            android:textColor="@color/login_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Username Input -->
        <EditText
            android:id="@+id/editUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp"
            android:ems="10"
            android:hint="@string/str_hint_username"
            android:inputType="text"
            android:text="@string/str_default_admin"
            android:autofillHints="username"
            android:padding="12dp"
            android:textColor="@color/login_text_primary"
            android:textColorHint="@color/login_text_secondary" />

        <!-- Password Label -->
        <TextView
            android:id="@+id/textView5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_password"
            android:textColor="@color/login_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Password Input -->
        <EditText
            android:id="@+id/editPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp"
            android:ems="10"
            android:hint="@string/str_hint_password"
            android:inputType="textPassword"
            android:text="@string/str_default_pwd"
            android:autofillHints="password"
            android:padding="12dp"
            android:textColor="@color/login_text_primary"
            android:textColorHint="@color/login_text_secondary" />

        <!-- Role Label -->
        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_login_role"
            android:textColor="@color/login_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Radio Group -->
        <RadioGroup
            android:id="@+id/RadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radAdmin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/str_login_admin"
                android:textColor="@color/login_primary"
                android:buttonTint="@color/login_primary" />

            <RadioButton
                android:id="@+id/radEmployee"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/str_login_employee"
                android:textColor="@color/login_primary"
                android:buttonTint="@color/login_primary" />

        </RadioGroup>

        <!-- Remember Me / Forgot Password Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/chkSaveInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/str_remember_me"
                android:textColor="@color/login_primary"
                android:buttonTint="@color/login_primary" />

            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="@string/str_forgot_password"
                android:textColor="@color/login_accent"
                android:textStyle="bold"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                style="?android:attr/buttonBarButtonStyle"
                android:onClick="loginSystem"
                android:id="@+id/btnLogin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/str_login"
                android:backgroundTint="@color/login_primary"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                style="?android:attr/buttonBarButtonStyle"
                android:onClick="exitSystem"
                android:id="@+id/btnExit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/str_exit"
                android:backgroundTint="@color/login_exit_bg"
                android:textColor="@color/login_exit_text"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Status Message -->
        <TextView
            android:id="@+id/txtMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/login_status_success"
            android:textAlignment="center"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
